---

<footer class="bg-batik-navy text-batik-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <div class="space-y-4">
        <h3 class="font-serif text-2xl font-bold text-batik-gold-light">Namina Batik</h3>
        <p class="text-batik-cream/80 text-sm leading-relaxed max-w-xs">
          UMKM Batik premium dari Bandung. Menghadirkan koleksi Batik berkualitas untuk pria dan wanita dengan desain elegan dan tradisi yang autentik.
        </p>
      </div>

      <div>
        <h4 class="font-semibold text-batik-gold-light mb-4">Quick Links</h4>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-batik-cream/80 hover:text-batik-gold transition-colors duration-300 text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-semibold text-batik-gold-light mb-4">Follow Us</h4>
        <div class="flex gap-4">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 flex items-center justify-center rounded-full bg-batik-cream/10 hover:bg-batik-gold hover:text-batik-navy transition-all duration-300"
              aria-label={link.label}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d={link.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-batik-cream/20 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-batik-cream/60 text-sm">
        © {currentYear} Namina Batik. All rights reserved.
      </p>
    </div>
  </div>
</footer>
