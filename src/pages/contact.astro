---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact | Namina Batik" description="Hubungi Namina Batik—kunjungi showroom di Cianjur, WhatsApp, Instagram, atau kirim pesan melalui form kontak kami.">
  <Navbar />

  <main class="min-h-screen">
    <section class="py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h1 class="font-serif text-3xl md:text-4xl font-bold text-batik-brown mb-4">Hubungi Kami</h1>
          <p class="text-batik-charcoal/80 text-lg leading-relaxed max-w-2xl mx-auto">
            Kunjungi showroom kami, atau hubungi melalui media sosial dan form di bawah ini.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
          <!-- Contact Form -->
          <div class="order-2 lg:order-1">
            <form class="bg-white rounded-2xl shadow-xl p-6 md:p-8 border border-batik-cream-dark/50" id="contact-form">
              <div class="space-y-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-batik-brown mb-2">Nama</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-lg border border-batik-cream-dark focus:ring-2 focus:ring-batik-gold focus:border-transparent text-batik-charcoal placeholder:text-batik-charcoal/50"
                    placeholder="Nama lengkap Anda"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-batik-brown mb-2">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-lg border border-batik-cream-dark focus:ring-2 focus:ring-batik-gold focus:border-transparent text-batik-charcoal placeholder:text-batik-charcoal/50"
                    placeholder="email@contoh.com"
                  />
                </div>
                <div>
                  <label for="subject" class="block text-sm font-medium text-batik-brown mb-2">Subjek</label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    class="w-full px-4 py-3 rounded-lg border border-batik-cream-dark focus:ring-2 focus:ring-batik-gold focus:border-transparent text-batik-charcoal placeholder:text-batik-charcoal/50"
                    placeholder="Tentang apa pesan Anda?"
                  />
                </div>
                <div>
                  <label for="message" class="block text-sm font-medium text-batik-brown mb-2">Pesan</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="5"
                    required
                    class="w-full px-4 py-3 rounded-lg border border-batik-cream-dark focus:ring-2 focus:ring-batik-gold focus:border-transparent text-batik-charcoal placeholder:text-batik-charcoal/50 resize-none"
                    placeholder="Tulis pesan Anda di sini..."
                  ></textarea>
                </div>
                <button
                  type="submit"
                  class="w-full py-4 bg-batik-gold hover:bg-batik-gold-light text-batik-brown font-semibold rounded-lg transition-all duration-300 hover:scale-[1.02]"
                >
                  Kirim Pesan
                </button>
              </div>
            </form>
          </div>

          <!-- Social & Info -->
          <div class="order-1 lg:order-2 space-y-8">
            <div>
              <h2 class="font-serif text-xl font-bold text-batik-brown mb-4">Media Sosial</h2>
              <div class="flex flex-col sm:flex-row gap-4">
                <a
                  href="https://wa.me/628128333918"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 px-6 py-4 bg-green-600 hover:bg-green-500 text-white font-medium rounded-lg transition-all duration-300 hover:scale-105"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  WhatsApp
                </a>
                <a
                  href="https://instagram.com/namina_batik"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-3 px-6 py-4 bg-pink-600 hover:bg-pink-500 text-white font-medium rounded-lg transition-all duration-300 hover:scale-105"
                >
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                  Instagram
                </a>
                <a
                  href="mailto:hello@naminabatik.com"
                  class="flex items-center gap-3 px-6 py-4 bg-batik-gold hover:bg-batik-gold-light text-batik-brown font-medium rounded-lg transition-all duration-300 hover:scale-105"
                >
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  Email
                </a>
              </div>
            </div>

            <div>
              <h2 class="font-serif text-xl font-bold text-batik-brown mb-4">Lokasi</h2>
              <p class="text-batik-charcoal/80 text-lg leading-relaxed mb-4">
                Perumahan Taman Bilqis Regency Jl Surakarta Blok bb5
              </p>
              <div class="rounded-2xl overflow-hidden shadow-xl border border-batik-cream-dark">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.303402786!2d107.60827631477273!3d-6.971038294961521!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e68e9a6995a8e0b%3A0x67563f5b33071b5!2sGedung%20Sate%2C%20Cianjur!5e0!3m2!1sid!2sid!4v1640000000000!5m2!1sid!2sid"
                  width="100%"
                  height="300"
                  style="border:0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Lokasi Namina Batik di Cianjur"
                  class="w-full"
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Terima kasih! Pesan Anda telah diterima. Kami akan segera menghubungi Anda.');
    (e.target as HTMLFormElement).reset();
  });
</script>
